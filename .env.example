# .env.example
# This file serves as a template for required environment variables.
# Copy this file to '.env' and replace the placeholder values with your actual secrets.

# MongoDB Connection String (e.g., mongodb+srv://<user>:<password>@cluster.mongodb.net/collabryx)
MONGO_URI=your_mongodb_cluster_uri_here

# JSON Web Token Secret used for signing authentication tokens securely
JWT_SECRET=your_super_secret_jwt_key_here

# Port for the Node.js backend to listen on
PORT=5000
